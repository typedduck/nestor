FROM debian:12

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        systemd \
        systemd-sysv \
        dbus \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Mask units that fail or are irrelevant inside a container
RUN systemctl mask \
    dev-hugepages.mount \
    sys-fs-fuse-connections.mount \
    systemd-update-utmp.service \
    getty.target \
    console-getty.service \
    2>/dev/null || true

STOPSIGNAL SIGRTMIN+3
CMD ["/lib/systemd/systemd"]
